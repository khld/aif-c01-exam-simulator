[\n  {\n    "id": "Q121",\n    "domain": "d4",\n    "question": "Which option is a benefit of using Amazon SageMaker Model Cards to document AI models?",\n    "options": {\n      "A": "Providing a visually appealing summary of a model's capabilities.",\n      "B": "Standardizing information about a model's purpose, performance, and limitations.",\n      "C": "Reducing the overall computational requirements of a model.",\n      "D": "Physically storing models for archival purposes."\n    },\n    "answer": "B",\n    "explanation": "SageMaker Model Cards standardize documentation about a model's purpose, performance, intended usage, and known limitations. It does not reduce compute requirements or physically store models."\n  },\n  {\n    "id": "Q122",\n    "domain": "d3",\n    "question": "A pharmaceutical company wants to analyze user reviews of new medications and provide a concise overview for each medication. Which solution meets these requirements?",\n    "options": {\n      "A": "Create a time-series forecasting model to analyze the medication reviews by using Amazon Personalize.",\n      "B": "Create medication review summaries by using Amazon Bedrock large language models (LLMs).",\n      "C": "Create a classification model that categorizes medications into different groups by using Amazon SageMaker.",\n      "D": "Create medication review summaries by using Amazon Rekognition."\n    },\n    "answer": "B",\n    "explanation": "Amazon Bedrock LLMs are optimized for natural language understanding and text summarization. Rekognition is for images; Personalize is for recommendations; SageMaker classification doesn't summarize text."\n  },\n  {\n    "id": "Q123",\n    "domain": "d1",\n    "question": "What does an F1 score measure in the context of foundation model (FM) performance?",\n    "options": {\n      "A": "Model precision and recall.",\n      "B": "Model speed in generating responses.",\n      "C": "Financial cost of operating the model.",\n      "D": "Energy efficiency of the model's computations."\n    },\n    "answer": "A",\n    "explanation": "The F1 score is the harmonic mean of precision and recall, a balanced metric for evaluating performance especially with class imbalance."\n  },\n  {\n    "id": "Q124",\n    "domain": "d1",\n    "question": "A company needs to train an ML model to classify images of different types of animals. The company has a large dataset of labeled images and will not label more data. Which type of learning should the company use?",\n    "options": {\n      "A": "Supervised learning.",\n      "B": "Unsupervised learning.",\n      "C": "Reinforcement learning.",\n      "D": "Active learning."\n    },\n    "answer": "A",\n    "explanation": "Supervised learning is appropriate when the dataset is labeled and the task is classification."\n  },\n  {\n    "id": "Q125",\n    "domain": "d3",\n    "question": "A company deployed an AI/ML solution to help customer service agents respond to frequently asked questions. The questions can change over time. Which strategy will meet these requirements MOST cost-effectively?",\n    "options": {\n      "A": "Fine-tune the model regularly.",\n      "B": "Train the model by using context data.",\n      "C": "Pre-train and benchmark the model by using context data.",\n      "D": "Use Retrieval Augmented Generation (RAG) with prompt engineering techniques."\n    },\n    "answer": "D",\n    "explanation": "RAG combines pre-trained models with retrieval mechanisms, eliminating the need for frequent retraining and keeping responses up to date cost-effectively."\n  },\n  {\n    "id": "Q126",\n    "domain": "d4",\n    "question": "A company built an AI-powered resume screening system trained on a dataset that was not representative of all demographics. Which core dimension of responsible AI does this scenario present?",\n    "options": {\n      "A": "Fairness.",\n      "B": "Explainability.",\n      "C": "Privacy and security.",\n      "D": "Transparency."\n    },\n    "answer": "A",\n    "explanation": "Non-representative training data leads to biased predictions affecting specific demographics \u2014 a core fairness problem."\n  },\n  {\n    "id": "Q127",\n    "domain": "d1",\n    "question": "A retail store wants to predict product demand for the next few weeks using Amazon SageMaker DeepAR. Which type of data meets this requirement?",\n    "options": {\n      "A": "Text data.",\n      "B": "Image data.",\n      "C": "Time series data.",\n      "D": "Binary data."\n    },\n    "answer": "C",\n    "explanation": "DeepAR is designed for scalar time series forecasting. Historical sales figures indexed over time are the correct input."\n  },\n  {\n    "id": "Q128",\n    "domain": "d1",\n    "question": "What does an F1 score measure in the context of foundation model (FM) performance? [Duplicate of Q123]",\n    "options": {\n      "A": "Model precision and recall.",\n      "B": "Model speed in generating responses.",\n      "C": "Financial cost of operating the model.",\n      "D": "Energy efficiency of the model's computations."\n    },\n    "answer": "A",\n    "explanation": "The F1 score is the harmonic mean of precision and recall. Note: this question is an exact duplicate of Q123."\n  },\n  {\n    "id": "Q129",\n    "domain": "d4",\n    "question": "Which AWS feature records details about ML instance data for governance and reporting?",\n    "options": {\n      "A": "Amazon SageMaker Model Cards",\n      "B": "Amazon SageMaker Debugger",\n      "C": "Amazon SageMaker Model Monitor",\n      "D": "Amazon SageMaker JumpStart"\n    },\n    "answer": "A",\n    "explanation": "SageMaker Model Cards provide a centralized, standardized repository for documenting model details including governance and reporting information."\n  },\n  {\n    "id": "Q130",\n    "domain": "d5",\n    "question": "A company is testing the security of a foundation model (FM). During testing, the company wants to get around the safety features and make harmful content. Which security technique is this an example of?",\n    "options": {\n      "A": "Fuzzing training data to find vulnerabilities.",\n      "B": "Denial of service (DoS).",\n      "C": "Penetration testing with authorization.",\n      "D": "Jailbreak."\n    },\n    "answer": "D",\n    "explanation": "A jailbreak is an attempt to bypass a model's safety guardrails to produce harmful content."\n  },\n  {\n    "id": "Q131",\n    "domain": "d5",\n    "question": "A company must comply with regulatory requirements to run SageMaker jobs in an isolated environment without internet access. Which solution meets these requirements?",\n    "options": {\n      "A": "Run SageMaker training and inference by using SageMaker Experiments.",\n      "B": "Run SageMaker training and inference by using network isolation.",\n      "C": "Encrypt the data at rest by using encryption for SageMaker geospatial capabilities.",\n      "D": "Associate appropriate IAM roles with the SageMaker jobs."\n    },\n    "answer": "B",\n    "explanation": "Network isolation in SageMaker prevents outbound network calls, ensuring jobs run in a fully isolated environment without internet access."\n  },\n  {\n    "id": "Q132",\n    "domain": "d4",\n    "question": "An ML team shares model artifacts with other teams. The ML team wants to build a mechanism to audit models. Which solution should the ML team use when publishing custom ML models?",\n    "options": {\n      "A": "Create documents with the relevant information. Store the documents in Amazon S3.",\n      "B": "Use AWS AI Service Cards for transparency and understanding models.",\n      "C": "Create Amazon SageMaker Model Cards with intended uses and training and inference details.",\n      "D": "Create model training scripts. Commit the model training scripts to a Git repository."\n    },\n    "answer": "C",\n    "explanation": "SageMaker Model Cards are purpose-built for documenting model metadata, enabling auditing across teams."\n  },\n  {\n    "id": "Q133",\n    "domain": "d3",\n    "question": "A software company builds tools for customers and wants to use AI to increase software development productivity. Which solution meets these requirements?",\n    "options": {\n      "A": "Use a binary classification model to generate code reviews.",\n      "B": "Install code recommendation software in the company's developer tools.",\n      "C": "Install a code forecasting tool to predict potential code issues.",\n      "D": "Use a natural language processing (NLP) tool to generate code."\n    },\n    "answer": "B",\n    "explanation": "Code recommendation software (like Amazon Q Developer) directly integrates into developer tools to suggest code, boosting productivity."\n  },\n  {\n    "id": "Q134",\n    "domain": "d5",\n    "question": "Which prompting attack directly exposes the configured behavior of a large language model (LLM)?",\n    "options": {\n      "A": "Prompted persona switches.",\n      "B": "Exploiting friendliness and trust.",\n      "C": "Ignoring the prompt template.",\n      "D": "Extracting the prompt template."\n    },\n    "answer": "D",\n    "explanation": "Extracting the prompt template is a prompt injection attack that directly reveals the system prompt or configured behavior of the LLM."\n  },\n  {\n    "id": "Q135",\n    "domain": "d4",\n    "question": "A large retail bank wants to develop an ML system to help the risk management team decide on loan allocations. What must the bank do to develop an unbiased ML model?",\n    "options": {\n      "A": "Reduce the size of the training dataset.",\n      "B": "Ensure that the ML model predictions are consistent with historical results.",\n      "C": "Create a different ML model for each demographic group.",\n      "D": "Measure class imbalance on the training dataset. Adapt the training process accordingly."\n    },\n    "answer": "D",\n    "explanation": "Measuring and correcting class imbalance in training data is the key step to reduce demographic bias in loan approval models."\n  },\n  {\n    "id": "Q136",\n    "domain": "d5",\n    "question": "Which prompting technique can protect against prompt injection attacks?",\n    "options": {\n      "A": "Adversarial prompting.",\n      "B": "Zero-shot prompting.",\n      "C": "Least-to-most prompting.",\n      "D": "Chain-of-thought prompting."\n    },\n    "answer": "A",\n    "explanation": "Adversarial prompting tests and hardens the model against injection attempts by exposing it to attack patterns during design."\n  },\n  {\n    "id": "Q137",\n    "domain": "d1",\n    "question": "A company has fine-tuned an LLM for a help desk and wants to determine if fine-tuning enhanced accuracy. Which metric should the company use?",\n    "options": {\n      "A": "Precision.",\n      "B": "Time to first token.",\n      "C": "F1 score.",\n      "D": "Word error rate."\n    },\n    "answer": "C",\n    "explanation": "F1 score balances precision and recall, making it the best metric to evaluate fine-tuning accuracy improvements for a QA help desk."\n  },\n  {\n    "id": "Q138",\n    "domain": "d3",\n    "question": "A company is using RAG with Amazon Bedrock and Stable Diffusion to generate product images. Results are random and lack specific details. The company wants to increase specificity. Which solution meets these requirements?",\n    "options": {\n      "A": "Increase the number of generation steps.",\n      "B": "Use the MASK_IMAGE_BLACK mask source option.",\n      "C": "Increase the classifier-free guidance (CFG) scale.",\n      "D": "Increase the prompt strength."\n    },\n    "answer": "C",\n    "explanation": "The CFG scale controls how closely the image generation follows the prompt. Increasing it makes results more specific and aligned with the prompt."\n  },\n  {\n    "id": "Q139",\n    "domain": "d3",\n    "question": "A company wants to implement an LLM-based chatbot for real-time customer service using company policies as the knowledge base. Which solution meets these requirements MOST cost-effectively?",\n    "options": {\n      "A": "Retrain the LLM on the company policy data.",\n      "B": "Fine-tune the LLM on the company policy data.",\n      "C": "Implement Retrieval Augmented Generation (RAG) for in-context responses.",\n      "D": "Use pre-training and data augmentation on the company policy data."\n    },\n    "answer": "C",\n    "explanation": "RAG retrieves relevant policy content at inference time without retraining, making it the most cost-effective solution for up-to-date contextual responses."\n  },\n  {\n    "id": "Q140",\n    "domain": "d3",\n    "question": "A company wants to create a new solution using AWS Glue with minimal programming experience. Which AWS service can help?",\n    "options": {\n      "A": "Amazon Q Developer",\n      "B": "AWS Config",\n      "C": "Amazon Personalize",\n      "D": "Amazon Comprehend"\n    },\n    "answer": "A",\n    "explanation": "Amazon Q Developer provides AI-powered coding assistance, including generating and explaining AWS Glue code for developers with minimal experience."\n  },\n  {\n    "id": "Q141",\n    "domain": "d4",\n    "question": "A company is developing a mobile ML app that uses diverse insect bite photos from different genders, ethnicities, and geographic locations. Which principle of responsible AI does the company demonstrate?",\n    "options": {\n      "A": "Fairness",\n      "B": "Explainability",\n      "C": "Governance",\n      "D": "Transparency"\n    },\n    "answer": "A",\n    "explanation": "Collecting diverse, representative data across demographics reflects the fairness principle of responsible AI, reducing potential model bias."\n  },\n  {\n    "id": "Q142",\n    "domain": "d4",\n    "question": "A company is developing an ML model for loan approvals and must detect bias and explain predictions. Which solution meets these requirements?",\n    "options": {\n      "A": "Amazon SageMaker Clarify",\n      "B": "Amazon SageMaker Data Wrangler",\n      "C": "Amazon SageMaker Model Cards",\n      "D": "AWS AI Service Cards"\n    },\n    "answer": "A",\n    "explanation": "SageMaker Clarify provides bias detection and explainability features, including feature attribution and fairness metrics for model predictions."\n  },\n  {\n    "id": "Q143",\n    "domain": "d2",\n    "question": "A company has developed a generative text summarization model using Amazon Bedrock. Which metric should the company use to evaluate accuracy?",\n    "options": {\n      "A": "Area Under the ROC Curve (AUC) score.",\n      "B": "F1 score.",\n      "C": "BERTScore.",\n      "D": "Real world knowledge (RWK) score."\n    },\n    "answer": "C",\n    "explanation": "BERTScore uses BERT embeddings to evaluate semantic similarity between generated and reference text, making it ideal for text summarization evaluation."\n  },\n  {\n    "id": "Q144",\n    "domain": "d1",\n    "question": "An AI practitioner wants to predict flower classification based on petal and sepal dimensions. Which algorithm meets these requirements?",\n    "options": {\n      "A": "K-nearest neighbors (k-NN).",\n      "B": "K-means.",\n      "C": "Autoregressive Integrated Moving Average (ARIMA).",\n      "D": "Linear regression."\n    },\n    "answer": "A",\n    "explanation": "k-NN is a supervised classification algorithm well suited for predicting flower species based on dimensional features like the classic Iris dataset."\n  },\n  {\n    "id": "Q145",\n    "domain": "d5",\n    "question": "A company wants to use a company-managed encryption key to encrypt model artifacts created by Amazon Bedrock customization jobs. Which AWS service meets these requirements?",\n    "options": {\n      "A": "AWS Key Management Service (AWS KMS)",\n      "B": "Amazon Inspector",\n      "C": "Amazon Macie",\n      "D": "AWS Secrets Manager"\n    },\n    "answer": "A",\n    "explanation": "AWS KMS allows customers to create and manage their own encryption keys (CMKs) for encrypting Amazon Bedrock model artifacts."\n  },\n  {\n    "id": "Q146",\n    "domain": "d2",\n    "question": "A company wants to use LLMs to produce code from natural language code comments. Which LLM feature meets these requirements?",\n    "options": {\n      "A": "Text summarization.",\n      "B": "Text generation.",\n      "C": "Text completion.",\n      "D": "Text classification."\n    },\n    "answer": "B",\n    "explanation": "Text generation allows an LLM to produce new content \u2014 in this case, generating code from natural language comments."\n  },\n  {\n    "id": "Q147",\n    "domain": "d2",\n    "question": "A language learning app makes text more coherent using an LLM. The company collected paired text examples of original and improved readable versions. Which metric should assess whether the LLM meets requirements?",\n    "options": {\n      "A": "Value of the loss function.",\n      "B": "Semantic robustness.",\n      "C": "Recall-Oriented Understudy for Gisting Evaluation (ROUGE) score.",\n      "D": "Latency of the text generation."\n    },\n    "answer": "C",\n    "explanation": "ROUGE measures overlap between generated and reference text, making it suitable for evaluating how closely the LLM's coherent output matches the provided readable examples."\n  },\n  {\n    "id": "Q148",\n    "domain": "d3",\n    "question": "A company notices that its foundation model generates images unrelated to prompts. Which solution meets these requirements to decrease unrelated images?",\n    "options": {\n      "A": "Use zero-shot prompts.",\n      "B": "Use negative prompts.",\n      "C": "Use positive prompts.",\n      "D": "Use ambiguous prompts."\n    },\n    "answer": "B",\n    "explanation": "Negative prompts tell the image model what to exclude from the output, reducing generation of unrelated content."\n  },\n  {\n    "id": "Q149",\n    "domain": "d3",\n    "question": "A company wants to use an LLM to generate concise, feature-specific product descriptions. Which prompt engineering technique meets these requirements?",\n    "options": {\n      "A": "Create one prompt covering all products, edit responses to be specific.",\n      "B": "Create prompts for each product category that highlight key features, including desired output format and length.",\n      "C": "Include diverse product features in each prompt for creative descriptions.",\n      "D": "Provide detailed, product-specific prompts for precise customized descriptions."\n    },\n    "answer": "B",\n    "explanation": "Category-specific prompts that specify format and length produce consistent, concise, and feature-focused descriptions at scale."\n  },\n  {\n    "id": "Q150",\n    "domain": "d1",\n    "question": "A company is developing an ML model to predict customer churn. The model performs well on training data but poorly on new data. Which solution resolves this issue?",\n    "options": {\n      "A": "Decrease the regularization parameter to increase model complexity.",\n      "B": "Increase the regularization parameter to decrease model complexity.",\n      "C": "Add more features to the input data.",\n      "D": "Train the model for more epochs."\n    },\n    "answer": "B",\n    "explanation": "Poor generalization indicates overfitting. Increasing regularization reduces model complexity, penalizing large weights and improving generalization."\n  },\n  {\n    "id": "Q151",\n    "domain": "d3",\n    "question": "A company is implementing conversational search using generative AI and needs a database service for storing and querying vector embeddings. Which AWS service meets these requirements?",\n    "options": {\n      "A": "Amazon Athena",\n      "B": "Amazon Aurora PostgreSQL",\n      "C": "Amazon Redshift",\n      "D": "Amazon EMR"\n    },\n    "answer": "B",\n    "explanation": "Amazon Aurora PostgreSQL supports the pgvector extension, enabling native vector storage and similarity search for embeddings in generative AI applications."\n  },\n  {\n    "id": "Q152",\n    "domain": "d4",\n    "question": "A financial institution is building an AI solution for loan approval decisions using a foundation model. For security and audit purposes, decisions must be explainable. Which factor relates to explainability?",\n    "options": {\n      "A": "Model complexity.",\n      "B": "Training time.",\n      "C": "Number of hyperparameters.",\n      "D": "Deployment time."\n    },\n    "answer": "A",\n    "explanation": "Model complexity directly affects explainability \u2014 simpler models (e.g., logistic regression) are inherently more interpretable than complex deep learning models."\n  },\n  {\n    "id": "Q153",\n    "domain": "d5",\n    "question": "A company wants to review which security aspects they are responsible for when using Amazon Bedrock. Which security aspect is the company responsible for?",\n    "options": {\n      "A": "Patching and updating the versions of Amazon Bedrock.",\n      "B": "Protecting the infrastructure that hosts Amazon Bedrock.",\n      "C": "Securing the company's data in transit and at rest.",\n      "D": "Provisioning Amazon Bedrock within the company network."\n    },\n    "answer": "C",\n    "explanation": "Under the AWS Shared Responsibility Model, the customer is responsible for securing their own data in transit and at rest, while AWS manages infrastructure patching and hosting."\n  },\n  {\n    "id": "Q154",\n    "domain": "d1",\n    "question": "A company wants to build a lead prioritization application where employees can view and adjust the weights of model variables. Which ML model type meets these requirements?",\n    "options": {\n      "A": "Logistic regression model.",\n      "B": "Deep learning model built on principal components.",\n      "C": "K-nearest neighbors (k-NN) model.",\n      "D": "Neural network."\n    },\n    "answer": "A",\n    "explanation": "Logistic regression has explicit, adjustable coefficients (weights) that users can view and modify, making it ideal for interpretable lead prioritization."\n  },\n  {\n    "id": "Q155",\n    "domain": "d2",\n    "question": "Which strategy will determine if a foundation model (FM) effectively meets business objectives?",\n    "options": {\n      "A": "Evaluate the model's performance on benchmark datasets.",\n      "B": "Analyze the model's architecture and hyperparameters.",\n      "C": "Assess the model's alignment with specific use cases.",\n      "D": "Measure the computational resources required for model deployment."\n    },\n    "answer": "C",\n    "explanation": "Assessing alignment with specific use cases directly determines whether the FM meets business objectives, beyond generic benchmark scores."\n  }\n]